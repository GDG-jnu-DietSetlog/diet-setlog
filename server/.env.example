# 절대 커밋 금지 — .env 는 .gitignore 됨. 이 파일은 키 없는 템플릿.
DATABASE_URL="postgresql://dietsetlog:dietsetlog@localhost:5432/dietsetlog?schema=public"
JWT_SECRET="dev-only-change-me"
PORT=3000
APP_TZ="Asia/Seoul"

# 인프라(analyses wave)
REDIS_URL="redis://localhost:6379"
# Google Cloud Storage — 로컬은 fake-gcs-server 에뮬레이터
GCS_PROJECT_ID="dietsetlog-local"
GCS_BUCKET="dietsetlog"
GCS_API_ENDPOINT="http://localhost:4443"   # 실제 GCS면 비워둔다(서비스계정 인증)
GCS_PUBLIC_URL="http://localhost:4443"

# Gemini 분석 — 키 없으면 목(mock)으로 동작
# GEMINI_API_KEY="..."
