{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(flutter pub *)",
      "Bash(flutter analyze *)",
      "Bash(flutter test *)",
      "Bash(flutter build *)",
      "Bash(flutter run *)",
      "Bash(flutter create *)",
      "Bash(flutter doctor)",
      "Bash(dart format *)",
      "Bash(dart run *)",
      "Bash(dart analyze *)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(pnpm *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(ls *)",
      "Read(./**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./apps/server/.env)",
      "Read(./apps/server/.env.*)",
      "Read(./secrets/**)",
      "Read(./keys/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./.git/**)"
    ]
  }
}
